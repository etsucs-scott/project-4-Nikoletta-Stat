@page "/"
@rendermode InteractiveServer
@using Sudoku.Core;

<h3>Sudoku</h3>

@* This component creates the actual 9x9 sudoku grid on the page. *@

<div class="sudoku-container">
    @if (SudokuBoard?.board == null)
    {
        <p>Loading...</p>
    }
    else
    {
        <table class="sudoku-grid">
            @for (int r = 0; r < 9; r++)
            {
                <tr>
                    @for (int c = 0; c < 9; c++)
                    {
                        var row = r;
                        var col = c;

                        var cell = SudokuBoard.board[row, col];
                        bool isSelected = SelectedRow == row && SelectedCol == col;

                        <td class="@GetCellCss(row, col, isSelected)"
                            @onclick="() => SelectCell(row, col)">
                            @if (cell.value != 0)
                            {
                                <span>@cell.value</span>
                            }
                            else
                            {
                                <span class="placeholder">.</span>
                            }
                        </td>
                    }
                </tr>
            }
        </table>
    }
</div>

@* Displays the stopwatch on the screen. *@

<p>Time: @TimeSpan.FromSeconds(elapsedSeconds).ToString(@"mm\:ss")</p>

@* Buttons to generate a new puzzle and fill in the current puzzle. *@

<div class="controls">
    <button @onclick="NewGame">New Game</button>
    <button @onclick="Solve">Solve</button>
</div>

@* Creates the number pad so users can enter in the number. *@

@if (SelectedRow != -1)
{
    <div class="number-pad">
        @for (int n = 1; n <= 9; n++)
        {
            var num = n;
            <button @onclick="() => EnterValue(num)">@n</button>
        }
        <button class="clear-btn" @onclick="() => ClearCell()">Clear</button>
    </div>
}

@* This creates the leaderboard at the bottom of the page if the user completes the game. *@

@if (ShowLeaderboard)
{
    <h3>Leaderboard</h3>
    <ul>
        @foreach (var score in leaderboard)
        {
            <li>@score</li>
        }
    </ul>
}


@code {

    private Board SudokuBoard = new();
    private PuzzleGenerator Generator = new();
    private PuzzleSolver Solver = new();

    private int SelectedRow = -1;
    private int SelectedCol = -1;

    private System.Timers.Timer? gameTimer;
    private int elapsedSeconds = 0;
    private bool gameRunning = false;
    private List<string> leaderboard = new();
    private bool ShowLeaderboard = false;

    // Had to override OnInitialized() so a new game would automatically pop up.

    protected override void OnInitialized()
    {
        NewGame();
    }

    // NewGame() generates a new puzzle with a hardcoded difficulty level of easy for testing purposes. It also starts the timer.

    private void NewGame()
    {
        SudokuBoard = Generator.GenerateNewPuzzle(DifficultyLevel.Easy);
        SelectedRow = -1;
        SelectedCol = -1;

        StartTimer();
    }

    // StartTimer() starts the timer for the game and updates the elapsed seconds.

    private void StartTimer()
    {
        elapsedSeconds = 0;
        gameRunning = true;

        gameTimer = new System.Timers.Timer(1000);
        gameTimer.Elapsed += (s, e) =>
        {
            elapsedSeconds++;
            InvokeAsync(StateHasChanged);
        };
        gameTimer.Start();
    }

    // StopTimer() stops the timer and ends the game.

    private void StopTimer()
    {
        gameRunning = false;
        gameTimer?.Stop();
    }

    // Solve() calls PuzzleSolver.Solved() and completes the board.

    private void Solve()
    {
        Solver.Solved(SudokuBoard);
    }

    // SelectCell() updates SelectedRow and SelectedCol to the cell the user clicks. If the cell is a given clue, it returns and doesn't update.

    private void SelectCell(int r, int c)
    {

        if (SudokuBoard?.board == null)
            return;

        if (SudokuBoard.board[r, c].given)
            return;

        SelectedRow = r;
        SelectedCol = c;

        StateHasChanged();
    }

    // EnterValue() takes in a number from the number pad and validates it with the game logic. It also checks for game completeness and 
    // will stop the timer and call the methods for updating the leaderboard.

    private void EnterValue(int n)
    {
        if (SelectedRow == -1 || SelectedCol == -1)
            return;

        if (SudokuBoard.board[SelectedRow, SelectedCol].given)
            return;

        SudokuBoard.board[SelectedRow, SelectedCol].value = n;

        if (!SudokuBoard.ValidRow(SelectedRow) ||
        !SudokuBoard.ValidCol(SelectedCol) ||
        !SudokuBoard.ValidBox(SelectedRow / 3, SelectedCol / 3))
        {
            SudokuBoard.board[SelectedRow, SelectedCol].value = 0;
            return;
        }

        if (SudokuBoard.Complete())
        {
            StopTimer();
            SaveScore(elapsedSeconds);
            Leaderboard();
            ShowLeaderboard = true;

        }
    }

    // ClearCell() resets a cell's value to zero.

    private void ClearCell()
    {
        if (SelectedRow == -1)
            return;

        SudokuBoard.board[SelectedRow, SelectedCol].value = 0;
    }

    // GetCellCss() formats the grid and values.

    private string GetCellCss(int r, int c, bool isSelected)
    {
        if (r < 0 || r > 8 || c < 0 || c > 8)
        {
            return "";
        }

        var classes = new List<string>();

        if (SudokuBoard.board[r, c].given)
            classes.Add("given");

        if (isSelected)
            classes.Add("selected");

        if (r % 3 == 0)
            classes.Add("top-border");

        if (c % 3 == 0)
            classes.Add("left-border");

        return string.Join(" ", classes);
    }

    // SaveScore() adds the DateTime and the number of elapsed seconds to the leaderboard.txt file. Looking back, I realize 
    // this isn't really a leaderboard, more so just a list of completion dates and seconds. 

    private void SaveScore(int seconds)
    {
        string path = "leaderboard.txt";
        string score = $"{DateTime.Now}: {seconds} seconds";

        File.AppendAllLines(path, new[] { score });
    }

    // Leaderboard() updates the leaderboard list to display on the page.

    private void Leaderboard()
    {
        string path = "leaderboard.txt";
        if (File.Exists(path))
        {
            leaderboard = File.ReadAllLines(path).ToList();
        }
    }
}